{
  "name": "elysian",
  "private": true,
  "packageManager": "bun@1.3.10",
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "hooks:install": "husky",
    "prepare": "husky",
    "pr:validate": "bun scripts/validate-pr-metadata.ts",
    "p5a:handoff:report": "bun scripts/p5a-schema-handoff-report.ts",
    "p5a:handoff:replay": "bun scripts/p5a-schema-handoff-replay.ts",
    "p5a:handoff:corpus": "bun scripts/p5a-handoff-corpus-run.ts",
    "p5a:acceptance": "bun scripts/p5a-acceptance.ts",
    "p5a:acceptance:gate": "bun scripts/p5a-acceptance-gate.ts",
    "p5a:acceptance:index": "bun scripts/p5a-acceptance-index.ts",
    "p5a:acceptance:finalize": "bun scripts/p5a-acceptance-finalize.ts",
    "dev:server": "bun --filter @elysian/server dev",
    "dev:vue": "bun --filter @elysian/example-vue dev",
    "dev:uniapp": "bun --filter @elysian/example-uniapp dev:h5",
    "server": "bun --filter @elysian/server start",
    "build:vue": "bun --filter @elysian/example-vue build",
    "build:uniapp": "bun --filter @elysian/example-uniapp build:h5",
    "db:generate": "bun --filter @elysian/persistence db:generate",
    "db:migrate": "bun --filter @elysian/persistence db:migrate",
    "db:seed": "bun --filter @elysian/persistence db:seed",
    "tenant:init": "bun --filter @elysian/persistence db:tenant:init",
    "db:studio": "bun --filter @elysian/persistence db:studio",
    "stack:up": "docker compose up --build",
    "stack:down": "docker compose down",
    "stack:reset": "docker compose down -v",
    "e2e:smoke": "bun scripts/e2e-smoke.ts",
    "e2e:smoke:full": "bun run db:migrate && bun run db:seed -- --reconcile-admin-password && bun run e2e:smoke",
    "e2e:tenant": "bun scripts/e2e-tenant-isolation.ts",
    "e2e:tenant:full": "bun run db:migrate && bun run db:seed && bun run e2e:tenant",
    "e2e:smoke:diagnose": "bun scripts/e2e-smoke-report-diagnose.ts",
    "e2e:smoke:reports:index": "bun scripts/e2e-smoke-reports-index.ts",
    "e2e:smoke:reports:gate": "bun scripts/e2e-smoke-reports-gate.ts",
    "e2e:smoke:stability:collect": "bun scripts/e2e-smoke-stability-collect.ts",
    "e2e:smoke:stability:snapshot": "bun scripts/e2e-smoke-stability-snapshot.ts",
    "e2e:smoke:stability:window": "bun scripts/e2e-smoke-stability-window.ts",
    "e2e:smoke:stability:evidence": "bun scripts/e2e-smoke-stability-evidence.ts",
    "e2e:smoke:phase:decision": "bun scripts/e2e-smoke-phase-transition-report.ts",
    "e2e:smoke:phase:gate": "bun scripts/e2e-smoke-phase-exit-gate.ts",
    "e2e:smoke:phase:finalize": "bun scripts/e2e-smoke-phase-finalize.ts",
    "e2e:smoke:phase:finalize:from-downloads": "bun scripts/e2e-smoke-phase-finalize-from-downloads.ts",
    "e2e:tenant:stability:download": "bun scripts/e2e-tenant-stability-download.ts",
    "e2e:tenant:stability:collect": "bun scripts/e2e-tenant-stability-collect.ts",
    "e2e:tenant:stability:snapshot": "bun scripts/e2e-tenant-stability-snapshot.ts",
    "e2e:tenant:stability:evidence": "bun scripts/e2e-tenant-stability-evidence.ts",
    "e2e:tenant:upgrade:decision": "bun scripts/e2e-tenant-upgrade-decision.ts",
    "e2e:tenant:upgrade:gate": "bun scripts/e2e-tenant-upgrade-gate.ts",
    "e2e:tenant:upgrade:finalize": "bun scripts/e2e-tenant-upgrade-finalize.ts",
    "e2e:tenant:upgrade:finalize:from-downloads": "bun scripts/e2e-tenant-upgrade-finalize-from-downloads.ts",
    "e2e:tenant:upgrade:finalize:from-github": "bun scripts/e2e-tenant-upgrade-finalize-from-github.ts",
    "tenant:release:report": "bun scripts/tenant-release-report.ts",
    "tenant:release:gate": "bun scripts/tenant-release-gate.ts",
    "tenant:release:finalize": "bun scripts/tenant-release-finalize.ts",
    "e2e:generator:safe-apply": "bun scripts/e2e-generator-safe-apply.ts",
    "e2e:generator:matrix": "bun scripts/e2e-generator-regression-matrix.ts",
    "e2e:generator:cli": "bun scripts/e2e-generator-cli.ts",
    "e2e:generator:reports:index": "bun scripts/e2e-generator-reports-index.ts",
    "e2e:generator:reports:gate": "bun scripts/e2e-generator-reports-gate.ts",
    "lint": "bunx @biomejs/biome@1.9.4 check .",
    "format": "bunx @biomejs/biome@1.9.4 format --write .",
    "check": "bun run lint && bun run typecheck && bun run test",
    "typecheck": "bunx tsc --noEmit -p tsconfig.json",
    "test": "bun test"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@types/bun": "^1.3.2",
    "husky": "^9.1.7",
    "typescript": "^5.9.3"
  }
}
