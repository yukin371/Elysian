{
  "compilerOptions": {
    "lib": ["ESNext"],
    "target": "ESNext",
    "module": "Preserve",
    "moduleDetection": "force",
    "jsx": "react-jsx",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "baseUrl": ".",
    "types": ["bun"],
    "paths": {
      "@elysian/core": ["packages/core/src/index.ts"],
      "@elysian/schema": ["packages/schema/src/index.ts"],
      "@elysian/ui-core": ["packages/ui-core/src/index.ts"],
      "@elysian/ui-enterprise-vue": ["packages/ui-enterprise-vue/src/index.ts"],
      "@elysian/persistence": ["packages/persistence/src/index.ts"],
      "@elysian/generator": ["packages/generator/src/index.ts"],
      "@elysian/generator/browser": ["packages/generator/src/browser.ts"],
      "@elysian/frontend-vue": ["packages/frontend-vue/src/index.ts"],
      "@elysian/frontend-react": ["packages/frontend-react/src/index.ts"]
    }
  },
  "include": ["apps/**/*.ts", "apps/**/*.d.ts", "packages/**/*.ts"]
}
