#!/usr/bin/env bash
# pre-push hook - 推送前兜底检查
# 检查: 协作者标识、协作者目录、历史中遗留的水印内容

set -eo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
NC='\033[0m'

FORBIDDEN_PATH_PATTERN='^(\.claude/|\.cursor/|\.windsurf/|\.codeium/|\.copilot/|\.aider/|\.roo/|\.augment/|docs/superpowers/)'
CONTENT_PATTERN='(Co-Authored-By:|Generated with .*(Claude|Anthropic|Copilot|Cursor|Windsurf|Codex)|>\s*\*\*For (Claude|Codex|Copilot|Cursor|Windsurf):\*\*)'
COMMIT_MSG_PATTERN='(^Co-Authored-By:|Generated with .*(Claude|Anthropic|Copilot|Cursor|Windsurf|Codex))'
WATERMARK_RULE_PATH_PATTERN='^(\.husky/|scripts/validate-pr-metadata\.ts|scripts/validate-pr-metadata\.test\.ts)$'
ZERO_SHA='0000000000000000000000000000000000000000'

HAS_ERROR=0

error() {
    echo -e "${RED}[XX]${NC} $1"
    HAS_ERROR=1
}

collect_commits() {
    local local_sha="$1"
    local remote_sha="$2"

    if [ "$local_sha" = "$ZERO_SHA" ]; then
        return 0
    fi

    if [ "$remote_sha" = "$ZERO_SHA" ]; then
        git rev-list "$local_sha" --not --remotes
        return 0
    fi

    if ! git cat-file -e "${remote_sha}^{commit}" 2>/dev/null; then
        git rev-list "$local_sha" --not --remotes
        return 0
    fi

    git rev-list "${remote_sha}..${local_sha}"
}

while read -r local_ref local_sha remote_ref remote_sha; do
    [ -z "$local_ref" ] && continue

    mapfile -t COMMITS < <(collect_commits "$local_sha" "$remote_sha")

    for commit in "${COMMITS[@]}"; do
        if git log --format=%B -n 1 "$commit" | grep -qE "$COMMIT_MSG_PATTERN"; then
            error "提交 $commit 的提交信息包含协作者水印"
        fi

        mapfile -d '' CHANGED_FILES < <(git diff-tree --no-commit-id --diff-filter=ACMR --name-only -r -z "$commit")

        if [ "${#CHANGED_FILES[@]}" -eq 0 ]; then
            continue
        fi

        CHECK_FILES=()
        for file in "${CHANGED_FILES[@]}"; do
            if [[ "$file" =~ $FORBIDDEN_PATH_PATTERN ]]; then
                error "提交 $commit 包含禁止推送的协作者目录: $file"
            fi

            if [[ "$file" =~ $WATERMARK_RULE_PATH_PATTERN ]]; then
                continue
            fi

            case "$file" in
                .husky/*) continue ;;
            esac

            CHECK_FILES+=("$file")
        done

        if [ "${#CHECK_FILES[@]}" -gt 0 ]; then
            for file in "${CHECK_FILES[@]}"; do
                if MATCHES=$(git show --format= --unified=0 "$commit" -- "$file" \
                    | grep -E '^\+[^+]' \
                    | grep -n -E "$CONTENT_PATTERN" 2>/dev/null); then
                    error "提交 $commit 包含协作者标识或水印内容: $file"
                    echo "$MATCHES"
                fi
            done
        fi
    done
done

if [ "$HAS_ERROR" -gt 0 ]; then
    echo -e "${RED}推送检查失败，请先清理协作者标识${NC}"
    exit 1
fi

# ── 单元测试 ────────────────────────────────────────────────

if ! bun test 2>&1; then
    error "单元测试失败，请修复后再推送"
fi

# ── Storybook 渲染检测 (仅当模板文件变更时) ──────────────────

STORY_PATTERN='\.(stories\.ts|template-i18n\.ts)$|storybook-template-pages\.css'

HAS_STORY_CHANGES=0
while read -r local_ref local_sha remote_ref remote_sha; do
    [ -z "$local_ref" ] && continue
    [ "$local_sha" = "$ZERO_SHA" ] && continue

    if [ "$remote_sha" = "$ZERO_SHA" ]; then
        CHANGED=$(git diff --name-only --remotes "$local_sha" 2>/dev/null || true)
    else
        CHANGED=$(git diff --name-only "$remote_sha" "$local_sha" 2>/dev/null || true)
    fi

    if echo "$CHANGED" | grep -qE "$STORY_PATTERN"; then
        HAS_STORY_CHANGES=1
        break
    fi
done

if [ "$HAS_STORY_CHANGES" -eq 1 ]; then
    echo -e "${GREEN}[..]${NC} 检测到 Story 模板变更，启动渲染检测..."

    if ! bun run build:storybook:vue 2>&1; then
        error "Storybook 构建失败"
    fi

    # 用静态构建服务跑 Playwright 渲染测试
    STORYBOOK_PID=""
    cleanup() {
        [ -n "$STORYBOOK_PID" ] && kill "$STORYBOOK_PID" 2>/dev/null || true
    }
    trap cleanup EXIT

    npx serve apps/storybook-vue/storybook-static -l 6006 -s &
    STORYBOOK_PID=$!
    sleep 3

    cd apps/storybook-vue
    if ! npx playwright test --reporter=list 2>&1; then
        cd "$OLDPWD"
        error "Storybook 渲染测试失败，请检查模板页面"
    fi
    cd "$OLDPWD"
fi

if [ "$HAS_ERROR" -gt 0 ]; then
    echo -e "${RED}推送检查失败${NC}"
    exit 1
fi

echo -e "${GREEN}[OK] 推送检查通过${NC}"
exit 0
