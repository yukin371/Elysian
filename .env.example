# ─── Server ───────────────────────────────────────────────
# Application environment: development | test | production
APP_ENV=development

# Server port
PORT=3000

# Log level: debug | info | warn | error
LOG_LEVEL=debug

# CORS allowed origins:
# - Use "*" to allow all origins (development default)
# - Or provide comma-separated origins (recommended for production)
CORS_ALLOWED_ORIGINS=*

# Basic in-memory rate limit policy
# In production, RATE_LIMIT_ENABLED defaults to true when omitted.
RATE_LIMIT_ENABLED=false
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=120

# JWT signing secret (required outside test environments)
ACCESS_TOKEN_SECRET=replace-with-a-local-dev-secret

# PostgreSQL defaults (used by docker-compose and local DB setup)
POSTGRES_DB=elysian
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# PostgreSQL connection string (required for customer module)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/elysian

# Default admin seed overrides (used by `bun run db:seed`)
ELYSIAN_ADMIN_USERNAME=admin
ELYSIAN_ADMIN_PASSWORD=admin123
ELYSIAN_ADMIN_DISPLAY_NAME=Administrator

# ─── Vue Example ──────────────────────────────────────────
# Backend API base URL (used by apps/example-vue)
VITE_API_BASE_URL=http://localhost:3000
